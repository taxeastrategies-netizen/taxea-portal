{
  "name": "PayrollExtraction",
  "type": "object",
  "properties": {
    "labor_ocr_document_id": {
      "type": "string"
    },
    "company_id": {
      "type": "string"
    },
    "employee_name": {
      "type": "string"
    },
    "employee_tax_id": {
      "type": "string"
    },
